# ── Database ──────────────────────────────────────────────────────────────────
# For local dev use a local Postgres instance.
# For production (Railway / Supabase) use the full connection URI.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/backero_cos

# ── Redis (optional — in-memory OTP store used as fallback) ──────────────────
# REDIS_URL=redis://localhost:6379/0

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── SMS — MSG91 (optional) ────────────────────────────────────────────────────
# If keys are blank, OTP is returned in the API response for dev/testing.
# MSG91_AUTH_KEY=your-msg91-auth-key
# MSG91_TEMPLATE_ID=your-otp-template-id
# MSG91_SENDER_ID=BACKRO

# ── WhatsApp — Meta Cloud API (optional) ─────────────────────────────────────
# Get from: Meta Business Suite → System Users → Generate Token
# WHATSAPP_ACCESS_TOKEN=your-permanent-token
# WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
# WHATSAPP_TEMPLATE_NAME=backero_notification

# ── Email — SMTP (optional) ───────────────────────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@backero.in
# SMTP_FROM_NAME=Backero COS

# ── Bootstrap admin ───────────────────────────────────────────────────────────
# Phone of the first Super Admin account (created on first run if not present)
ADMIN_PHONE=9999999999
ADMIN_NAME=Admin User

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app
