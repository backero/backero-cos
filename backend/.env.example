# ── Database (Supabase) ───────────────────────────────────────────────────────
# Get this from: Supabase → Project Settings → Database → Connection string (URI)
# Use the "Session mode" pooler URL (port 5432) for Railway compatibility
DATABASE_URL=postgresql+asyncpg://postgres:[PASSWORD]@[PROJECT].supabase.co:5432/postgres
postgresql://postgres:[YOUR-PASSWORD]@db.nzfgiiklpnkfctcwirzp.supabase.co:5432/postgres

# ── Redis (commented out — in-memory OTP store used for MVP) ─────────────────
# REDIS_URL=redis://localhost:6379/0

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── SMS / WhatsApp (not active — OTP is returned in API response for MVP) ─────
# MSG91_AUTH_KEY=your-msg91-auth-key
# MSG91_TEMPLATE_ID=your-otp-template-id
# MSG91_SENDER_ID=BACKRO
# INTERAKT_API_KEY=your-interakt-api-key

# ── Bootstrap admin ───────────────────────────────────────────────────────────
ADMIN_PHONE=9999999999
ADMIN_NAME=Admin User

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=production
# Add your Vercel frontend URL here (no trailing slash)
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app
